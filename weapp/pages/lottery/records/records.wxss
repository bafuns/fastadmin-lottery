/* pages/lottery/records/records.wxss */
page {
  background: #f5f5f5;
}

.container {
  min-height: 100vh;
}

/* 标签切换 */
.tabs {
  display: flex;
  background: #fff;
  padding: 20rpx;
  position: sticky;
  top: 0;
  z-index: 10;
}

.tab {
  flex: 1;
  text-align: center;
  padding: 15rpx 0;
  font-size: 28rpx;
  color: #666;
  position: relative;
}

.tab.active {
  color: #667eea;
  font-weight: bold;
}

.tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 4rpx;
  background: #667eea;
  border-radius: 2rpx;
}

/* 记录列表 */
.records-list {
  padding: 20rpx;
}

.record-item {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  align-items: center;
}

.record-left {
  margin-right: 20rpx;
}

.prize-icon {
  width: 100rpx;
  height: 100rpx;
  border-radius: 12rpx;
  background: #f5f5f5;
}

.record-center {
  flex: 1;
}

.prize-name {
  display: block;
  font-size: 30rpx;
  color: #333;
  font-weight: bold;
}

.prize-value {
  display: block;
  font-size: 26rpx;
  color: #999;
  margin-top: 8rpx;
}

.record-time {
  display: block;
  font-size: 24rpx;
  color: #ccc;
  margin-top: 8rpx;
}

.record-right {
  margin-left: 20rpx;
}

.status {
  font-size: 24rpx;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
}

.status-1 {
  background: #fff7e6;
  color: #fa8c16;
}

.status-2 {
  background: #e6f7ff;
  color: #1890ff;
}

.status-3 {
  background: #f5f5f5;
  color: #999;
}

/* 空状态 */
.empty {
  text-align: center;
  padding: 100rpx 0;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  opacity: 0.5;
}

.empty text {
  display: block;
  color: #999;
  font-size: 28rpx;
  margin-top: 20rpx;
}

/* 加载更多 */
.load-more {
  text-align: center;
  padding: 20rpx;
  color: #999;
  font-size: 26rpx;
}